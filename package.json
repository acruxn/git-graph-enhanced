{
  "name": "git-graph-enhanced",
  "displayName": "Git Graph Enhanced",
  "description": "High-performance git history visualization powered by Rust",
  "version": "0.1.0",
  "publisher": "git-graph-enhanced",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/acruxn/git-graph-enhanced.git"
  },
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": [
    "SCM Providers",
    "Visualization"
  ],
  "extensionKind": [
    "workspace"
  ],
  "activationEvents": [
    "workspaceContains:**/.git"
  ],
  "main": "./dist/extension.js",
  "capabilities": {
    "untrustedWorkspaces": {
      "supported": false
    }
  },
  "contributes": {
    "commands": [
      {
        "command": "gitGraphEnhanced.show",
        "title": "Show Git Graph",
        "category": "Git Graph Enhanced"
      },
      {
        "command": "gitGraphEnhanced.export",
        "title": "Export Graph as Image",
        "category": "Git Graph Enhanced"
      },
      {
        "command": "gitGraphEnhanced.openTerminal",
        "title": "Open Terminal at Repository",
        "category": "Git Graph Enhanced"
      },
      {
        "command": "gitGraphEnhanced.exportConfig",
        "title": "Export Configuration",
        "category": "Git Graph Enhanced"
      },
      {
        "command": "gitGraphEnhanced.importConfig",
        "title": "Import Configuration",
        "category": "Git Graph Enhanced"
      },
      {
        "command": "gitGraphEnhanced.showAll",
        "title": "Show All Repository Graphs",
        "category": "Git Graph Enhanced"
      }
    ],
    "configuration": {
      "title": "Git Graph Enhanced",
      "properties": {
        "gitGraphEnhanced.maxCommits": {
          "type": "number",
          "default": 500,
          "description": "Maximum number of commits to load per page"
        },
        "gitGraphEnhanced.requestTimeout": {
          "type": "number",
          "default": 30,
          "description": "Timeout in seconds for backend requests"
        },
        "gitGraphEnhanced.maxDepthOfRepoSearch": {
          "type": "number",
          "default": 1,
          "description": "Maximum folder depth to search for git repositories"
        },
        "gitGraphEnhanced.logLevel": {
          "type": "string",
          "default": "info",
          "enum": ["error", "warn", "info", "debug"],
          "description": "Log level for the output channel"
        },
        "gitGraphEnhanced.openOnStartup": {
          "type": "boolean",
          "default": false,
          "description": "Automatically open the graph when a workspace with a git repository is opened"
        },
        "gitGraphEnhanced.showDateColumn": {
          "type": "boolean",
          "default": true,
          "description": "Show date column in graph"
        },
        "gitGraphEnhanced.showAuthorColumn": {
          "type": "boolean",
          "default": true,
          "description": "Show author column in graph"
        },
        "gitGraphEnhanced.graphStyle": {
          "type": "string",
          "default": "curved",
          "enum": ["curved", "angular", "straight"],
          "description": "Graph edge style: curved (bezier), angular (right-angle), or straight lines"
        },
        "gitGraphEnhanced.issueLinking": {
          "type": "object",
          "default": {},
          "description": "Regex-to-URL mapping for issue linking. Example: { \"#(\\\\d+)\": \"https://github.com/owner/repo/issues/$1\" }",
          "additionalProperties": { "type": "string" }
        },
        "gitGraphEnhanced.branchGroups": {
          "type": "array",
          "default": [],
          "items": {
            "type": "object",
            "properties": {
              "label": { "type": "string" },
              "pattern": { "type": "string" }
            }
          },
          "description": "Custom branch groupings. Example: [{ \"label\": \"Features\", \"pattern\": \"feature/*\" }]"
        },
        "gitGraphEnhanced.showReflog": {
          "type": "boolean",
          "default": false,
          "description": "Include reflog entries in the graph"
        },
        "gitGraphEnhanced.prProvider": {
          "type": "string",
          "default": "auto",
          "enum": ["auto", "github", "gitlab", "bitbucket"],
          "description": "Pull request provider. 'auto' detects from remote URL."
        },
        "gitGraphEnhanced.accessibilityMode": {
          "type": "boolean",
          "default": false,
          "description": "Show text indicators (A/M/D/R) alongside colors for file status, distinct shapes for node types, and high-contrast focus rings"
        },
        "gitGraphEnhanced.promptForSshPassphrase": {
          "type": "boolean",
          "default": true,
          "description": "Prompt for SSH key passphrase when needed"
        }
      }
    }
  },
  "scripts": {
    "build": "node esbuild.mjs",
    "watch": "node esbuild.mjs --watch",
    "package": "vsce package",
    "package:target": "vsce package --target",
    "test": "vitest run"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "@vscode/vsce": "^2.22.0",
    "esbuild": "^0.20.0",
    "typescript": "^5.3.0",
    "vitest": "^1.0.0"
  }
}
